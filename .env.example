# MQTT Config
MQTT_BROKER_HOST=192.168.68.100
MQTT_BROKER_PORT=1883

# AI Config
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Anthropic Model Choice:
# - claude-3-5-sonnet-latest (Recommended: Best balance of speed/intelligence)
# - claude-3-5-haiku-latest   (Fastest, lower cost)
# - claude-3-opus-latest      (Most powerful, slower/expensive)
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Simulation Config
SIMULATION_MODE=auto

# Frontend Config (Vite)
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/stream
