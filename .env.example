# =============================================================
# Elicius Predictive Maintenance — Environment Configuration
# =============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================

# ── MQTT Configuration ──────────────────────────────────────
MQTT_BROKER_HOST=mqtt-broker
MQTT_BROKER_PORT=1883
# MQTT_USERNAME=          # Optional: MQTT broker username
# MQTT_PASSWORD=          # Optional: MQTT broker password

# ── AI / LLM Configuration ─────────────────────────────────
# Get your key from https://platform.openai.com/
OPENAI_API_KEY=
# Model choices:
#   gpt-4o        (Recommended: best intelligence)
#   gpt-4o-mini   (Fastest, lower cost)
OPENAI_MODEL=gpt-4o

# ── Authentication ─────────────────────────────────────────
# JWT secret key — CHANGE THIS to a random string in production!
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET-KEY
JWT_EXPIRY_MINUTES=480

# Admin credentials
# Username for the admin account
ADMIN_USERNAME=admin
# Password hash — generate with:
#   python3 -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
# Leave empty for dev mode (any password accepted — NOT for production!)
ADMIN_PASSWORD_HASH=

# ── Database ───────────────────────────────────────────────
DATABASE_PATH=/app/data/sensor_data.db
DATA_RETENTION_HOURS=720

# ── Simulation ─────────────────────────────────────────────
# auto: simulate if no MQTT data received
# always: always simulate
# never: only use real MQTT data
SIMULATION_MODE=auto

# ── Server ─────────────────────────────────────────────────
# CORS origins (comma-separated if multiple)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Frontend (Vite build-time variables) ───────────────────
# For local development:
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/stream
# For EC2 production: set these to your server IP/domain
# VITE_BACKEND_URL=http://<YOUR_EC2_IP>:8000
# VITE_WS_URL=ws://<YOUR_EC2_IP>:8000/ws/stream
